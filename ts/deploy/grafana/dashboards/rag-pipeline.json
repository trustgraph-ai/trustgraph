      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(tg_consumer_processing_total{job=~\"graph-rag|document-rag\", status=\"success\"}[5m])) by (job)",
